// Schema database ShadyERP — SaaS POS UMKM
// PostgreSQL (mis. Supabase) untuk pengembangan maupun produksi.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ================== TENANT & OUTLET ==================

enum BusinessType {
  FNB
  BARBERSHOP
  RETAIL
  SERVICE
  OTHER
}

enum Plan {
  FREE
  BASIC
  PRO
}

model Tenant {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  businessType BusinessType @default(OTHER)
  plan         Plan         @default(FREE)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  outlets           Outlet[]
  users             User[]
  uidBatches        UidBatch[]
  uidCards          UidCard[]
  members           Member[]
  pointTransactions PointTransaction[]
  categories        Category[]
  products          Product[]
  productStocks     ProductStock[]
  cashierShifts     CashierShift[]
  sales             Sale[]
  saleItems         SaleItem[]
  shiftSchedules    ShiftSchedule[]
  attendances       Attendance[]
  setting           TenantSetting?
}

model Outlet {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userOutlets    UserOutlet[]
  productStocks  ProductStock[]
  cashierShifts  CashierShift[]
  sales          Sale[]
  shiftSchedules ShiftSchedule[]
  attendances    Attendance[]

  @@index([tenantId])
}

// ================== USER & AKSES ==================

enum UserRole {
  OWNER
  MANAGER
  STAFF
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  name         String
  email        String    @unique
  phone        String?
  passwordHash String
  role         UserRole  @default(STAFF)
  pin          String? // PIN 6 digit, opsional (untuk kunci cepat kasir)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userOutlets       UserOutlet[]
  uidCardsAssigned  UidCard[]       @relation("EmployeeCard")
  cashierShifts     CashierShift[]
  salesAsCashier    Sale[]          @relation("SaleCashier")
  attendances       Attendance[]
  shiftSchedules    ShiftSchedule[]

  @@index([tenantId])
}

model UserOutlet {
  id       String @id @default(cuid())
  tenantId String
  userId   String
  outletId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, outletId])
  @@index([tenantId])
  @@index([outletId])
}

// ================== UNIVERSAL ID SYSTEM (KARTU QR) ==================

enum UidCardType {
  MEMBER
  EMPLOYEE
}

enum UidCardStatus {
  UNASSIGNED
  ACTIVE
  SUSPENDED
  LOST
}

model UidBatch {
  id            String      @id @default(cuid())
  tenantId      String
  cardType      UidCardType
  quantity      Int
  serialPrefix  String
  createdAt     DateTime    @default(now())

  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cards  UidCard[]

  @@index([tenantId])
}

model UidCard {
  id             String        @id @default(cuid())
  tenantId       String
  batchId        String?
  uid            String        @unique // ULID unik dicetak di kartu/QR
  serialNumber   String // contoh: MBR-0001, unik per tenant
  cardType       UidCardType
  status         UidCardStatus @default(UNASSIGNED)
  memberId       String?       @unique
  employeeUserId String?       @unique
  activatedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batch        UidBatch? @relation(fields: [batchId], references: [id])
  member       Member?  @relation(fields: [memberId], references: [id])
  employeeUser User?    @relation("EmployeeCard", fields: [employeeUserId], references: [id])

  @@unique([tenantId, serialNumber])
  @@index([tenantId])
  @@index([batchId])
}

// ================== MEMBER ==================

model Member {
  id             String   @id @default(cuid())
  tenantId       String
  name           String
  phone          String
  email          String?
  points         Int      @default(0)
  depositBalance Int      @default(0)
  joinedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  uidCard           UidCard?
  pointTransactions PointTransaction[]
  sales             Sale[]

  @@unique([tenantId, phone])
  @@index([tenantId])
}

enum PointTransactionType {
  EARN
  REDEEM
  ADJUST
}

model PointTransaction {
  id        String                @id @default(cuid())
  tenantId  String
  memberId  String
  type      PointTransactionType
  points    Int // bisa negatif untuk REDEEM/ADJUST
  saleId    String?
  note      String?
  createdAt DateTime              @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  sale   Sale?  @relation(fields: [saleId], references: [id])

  @@index([tenantId])
  @@index([memberId])
}

// ================== PRODUK & STOK ==================

model Category {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([tenantId])
}

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  categoryId  String?
  name        String
  sku         String?
  price       Int // Rupiah, tanpa sen
  cost        Int?
  imageUrl    String?
  trackStock  Boolean  @default(true)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])

  stocks    ProductStock[]
  saleItems SaleItem[]

  @@index([tenantId])
  @@index([categoryId])
}

model ProductStock {
  id        String   @id @default(cuid())
  tenantId  String
  productId String
  outletId  String
  qty       Int      @default(0)
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  outlet  Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@unique([productId, outletId])
  @@index([tenantId])
  @@index([outletId])
}

// ================== SHIFT KASIR ==================

enum ShiftStatus {
  OPEN
  CLOSED
}

model CashierShift {
  id           String      @id @default(cuid())
  tenantId     String
  outletId     String
  userId       String
  openingCash  Int
  closingCash  Int?
  expectedCash Int?
  status       ShiftStatus @default(OPEN)
  openedAt     DateTime    @default(now())
  closedAt     DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  sales Sale[]

  @@index([tenantId])
  @@index([outletId])
}

// ================== PENJUALAN ==================

enum PaymentMethod {
  CASH
  QRIS
  TRANSFER
  EWALLET
  DEPOSIT
}

enum SaleStatus {
  COMPLETED
  VOIDED
}

model Sale {
  id             String        @id @default(cuid())
  tenantId       String
  outletId       String
  shiftId        String?
  cashierId      String
  memberId       String?
  invoiceNumber  String        @unique
  subtotal       Int
  discountAmount Int           @default(0)
  taxAmount      Int           @default(0)
  total          Int
  paymentMethod  PaymentMethod
  amountPaid     Int
  changeAmount   Int           @default(0)
  status         SaleStatus    @default(COMPLETED)
  voidReason     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet Outlet        @relation(fields: [outletId], references: [id], onDelete: Cascade)
  shift  CashierShift? @relation(fields: [shiftId], references: [id])
  cashier User         @relation("SaleCashier", fields: [cashierId], references: [id])
  member Member?       @relation(fields: [memberId], references: [id])

  items             SaleItem[]
  pointTransactions PointTransaction[]

  @@index([tenantId])
  @@index([outletId])
  @@index([shiftId])
  @@index([memberId])
}

model SaleItem {
  id             String @id @default(cuid())
  tenantId       String
  saleId         String
  productId      String
  productName    String // snapshot nama produk saat transaksi
  price          Int    // snapshot harga saat transaksi
  qty            Int
  discountAmount Int    @default(0)
  subtotal       Int

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([saleId])
}

// ================== ABSENSI & JADWAL ==================

model ShiftSchedule {
  id        String   @id @default(cuid())
  tenantId  String
  outletId  String
  userId    String
  startAt   DateTime
  endAt     DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([outletId])
  @@index([userId])
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
}

model Attendance {
  id              String            @id @default(cuid())
  tenantId        String
  outletId        String
  userId          String
  clockInAt       DateTime?
  clockOutAt      DateTime?
  clockInPhotoUrl String?
  lat             Float?
  lng             Float?
  status          AttendanceStatus  @default(PRESENT)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([outletId])
  @@index([userId])
}

// ================== PENGATURAN TENANT ==================

model TenantSetting {
  id               String  @id @default(cuid())
  tenantId         String  @unique
  taxPercent       Int     @default(0)
  pointsPerAmount  Int     @default(10000) // 1 poin per Rp10.000
  receiptFooter    String?
  updatedAt        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}
