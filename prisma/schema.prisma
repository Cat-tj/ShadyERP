// Schema database ShadyERP — SaaS POS UMKM
// PostgreSQL (mis. Supabase) untuk pengembangan maupun produksi.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ================== SUPER ADMIN (LINTAS TENANT) ==================

/// SATU-SATUNYA model yang SENGAJA tidak punya tenantId — ini akun untuk
/// pemilik platform (Altora), bukan pengguna tenant mana pun. Sesinya
/// TERPISAH TOTAL dari NextAuth (lihat src/lib/super-admin-session.ts) supaya
/// tidak pernah bisa tertukar dengan sesi User biasa. Dipakai untuk memantau
/// semua tenant, suspend/aktifkan, dan mengonfirmasi pembayaran langganan.
model SuperAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())

  auditLogs SuperAdminAuditLog[]
}

model SuperAdminAuditLog {
  id             String   @id @default(cuid())
  actorId        String
  action         String
  targetTenantId String?
  description    String
  beforeJson     Json?
  afterJson      Json?
  createdAt      DateTime @default(now())

  actor SuperAdmin @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([targetTenantId])
  @@index([createdAt])
}

// ================== TENANT & OUTLET ==================

enum BusinessType {
  CAFE
  TOKO
  LAUNDRY
  COUNTER
  COMPANY
  FNB
  BARBERSHOP
  RETAIL
  SERVICE
  OTHER
}

enum Plan {
  FREE
  BASIC
  PRO
}

model Tenant {
  id              String       @id @default(cuid())
  name            String
  slug            String       @unique
  businessType    BusinessType @default(CAFE)
  plan            Plan         @default(FREE)
  isActive        Boolean      @default(true)
  /**
   * Key modul (lihat src/lib/modules.ts) yang dimatikan Superadmin Altora. Modul core tidak pernah masuk sini.
   */
  disabledModules String[]     @default([])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  outlets                  Outlet[]
  users                    User[]
  uidBatches               UidBatch[]
  uidCards                 UidCard[]
  members                  Member[]
  pointTransactions        PointTransaction[]
  stampTransactions        StampTransaction[]
  giftCards                GiftCard[]
  giftCardTransactions     GiftCardTransaction[]
  categories               Category[]
  products                 Product[]
  productStocks            ProductStock[]
  productUnavailabilityLogs ProductUnavailabilityLog[]
  cashierShifts            CashierShift[]
  sales                    Sale[]
  salePayments             SalePayment[]
  cashOutTransactions      CashOutTransaction[]
  saleItems                SaleItem[]
  saleReturns              SaleReturn[]
  saleReturnItems          SaleReturnItem[]
  shiftSchedules           ShiftSchedule[]
  attendances              Attendance[]
  stockAdjustments         StockAdjustment[]
  stockTransfers           StockTransfer[]
  expenses                 Expense[]
  tables                   Table[]
  tableOrders              TableOrder[]
  tableOrderItems          TableOrderItem[]
  subscriptionRequests     SubscriptionRequest[]
  productVariantGroups     ProductVariantGroup[]
  productVariantOptions    ProductVariantOption[]
  modifierGroups           ModifierGroup[]
  modifierOptions          ModifierOption[]
  productModifierExclusions ProductModifierExclusion[]
  auditLogs                AuditLog[]
  promos                   Promo[]
  bookings                 Booking[]
  equipments               Equipment[]
  equipmentMaintenanceLogs EquipmentMaintenanceLog[]
  reorderPoints            StockReorderPoint[]
  stockBatches             StockBatch[]
  productSerials           ProductSerial[]
  suppliers                Supplier[]
  supplierContracts        SupplierPricingContract[]
  purchaseOrders           PurchaseOrder[]
  stockReceipts            StockReceipt[]
  stockCounts              StockCount[]
  productCostHistory       ProductCostHistory[]
  documents                Document[]
  setting                  TenantSetting?
  productUoms              ProductUom[]
  wholesalePrices          WholesalePrice[]
  channelPricingRules      ChannelPricingRule[]
  productRecipeItems       ProductRecipeItem[]
  laundryOrders            LaundryOrder[]
  laundryServices          LaundryService[]
  supplierInvoices         SupplierInvoice[]
  supplierPayments         SupplierPayment[]
  accounts                 Account[]
  journalEntries           JournalEntry[]
  leads                    Lead[]
  cashFlows                CashFlow[]
  subscription             Subscription?
}

model Outlet {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  phone     String?
  /// Lebar kertas printer thermal outlet ini dalam mm — cuma 58 atau 80, dipakai buat format struk ESC/POS.
  receiptPaperWidth Int @default(58)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userOutlets              UserOutlet[]
  productStocks            ProductStock[]
  productUnavailabilityLogs ProductUnavailabilityLog[]
  cashierShifts            CashierShift[]
  sales                    Sale[]
  cashOutTransactions      CashOutTransaction[]
  shiftSchedules           ShiftSchedule[]
  attendances              Attendance[]
  stockAdjustments         StockAdjustment[]
  expenses                 Expense[]
  transfersFrom            StockTransfer[]           @relation("StockTransferFromOutlet")
  transfersTo              StockTransfer[]           @relation("StockTransferToOutlet")
  tables                   Table[]
  tableOrders              TableOrder[]
  bookings                 Booking[]
  equipments               Equipment[]
  equipmentMaintenanceLogs EquipmentMaintenanceLog[]
  reorderPoints            StockReorderPoint[]
  stockBatches             StockBatch[]
  productSerials           ProductSerial[]
  stockReceipts            StockReceipt[]
  stockCounts              StockCount[]
  laundryOrders            LaundryOrder[]
  cashFlows                CashFlow[]

  @@index([tenantId])
}

// ================== USER & AKSES ==================

enum UserRole {
  OWNER
  MANAGER
  STAFF
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  email        String   @unique
  phone        String?
  passwordHash String
  role         UserRole @default(STAFF)
  jobTitle     String?
  pin          String? // PIN 6 digit, opsional (untuk kunci cepat kasir)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userOutlets              UserOutlet[]
  uidCardsAssigned         UidCard[]                 @relation("EmployeeCard")
  cashierShifts            CashierShift[]
  salesAsCashier           Sale[]                    @relation("SaleCashier")
  cashOutTransactions      CashOutTransaction[]      @relation("CashOutCashier")
  saleReturnsProcessed     SaleReturn[]              @relation("SaleReturnProcessedBy")
  attendances              Attendance[]
  shiftSchedules           ShiftSchedule[]
  stockAdjustments         StockAdjustment[]
  expensesCreated          Expense[]
  stockTransfersCreated    StockTransfer[]           @relation("StockTransferCreatedBy")
  stockTransfersApproved   StockTransfer[]           @relation("StockTransferApprovedBy")
  stockTransfersSent       StockTransfer[]           @relation("StockTransferSentBy")
  stockTransfersReceived   StockTransfer[]           @relation("StockTransferReceivedBy")
  auditLogs                AuditLog[]
  bookingsAssigned         Booking[]
  equipmentMaintenanceLogs EquipmentMaintenanceLog[]
  purchaseOrdersApproved   PurchaseOrder[]
  stockReceiptsReceived    StockReceipt[]            @relation("StockReceiptReceivedBy")
  stockReceiptsChecked     StockReceipt[]            @relation("StockReceiptCheckedBy")
  stockCountsStarted       StockCount[]              @relation("StockCountStartedBy")
  stockCountsCompleted     StockCount[]              @relation("StockCountCompletedBy")
  stockCountsVerified      StockCount[]              @relation("StockCountVerifiedBy")
  costHistoryChanges       ProductCostHistory[]
  documentsUploaded        Document[]                @relation("DocumentUploader")
  giftCardsSold            GiftCard[]
  documentVersions         DocumentVersion[]
  documentSignings         DocumentSigner[]
  documentAccess           DocumentAccess[]
  laundryOrdersCreated     LaundryOrder[]            @relation("LaundryOrderCreatedBy")
  cashFlowsCreated         CashFlow[]                @relation("UserCashFlows")

  @@index([tenantId])
}

model UserOutlet {
  id       String @id @default(cuid())
  tenantId String
  userId   String
  outletId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, outletId])
  @@index([tenantId])
  @@index([outletId])
}

// ================== UNIVERSAL ID SYSTEM (KARTU QR) ==================

enum UidCardType {
  MEMBER
  EMPLOYEE
}

enum UidCardStatus {
  UNASSIGNED
  ACTIVE
  SUSPENDED
  LOST
}

model UidBatch {
  id           String      @id @default(cuid())
  tenantId     String
  cardType     UidCardType
  quantity     Int
  serialPrefix String
  createdAt    DateTime    @default(now())

  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cards  UidCard[]

  @@index([tenantId])
}

model UidCard {
  id             String        @id @default(cuid())
  tenantId       String
  batchId        String?
  uid            String        @unique // ULID unik dicetak di kartu/QR
  serialNumber   String // contoh: MBR-0001, unik per tenant
  cardType       UidCardType
  status         UidCardStatus @default(UNASSIGNED)
  memberId       String?       @unique
  employeeUserId String?       @unique
  activatedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batch        UidBatch? @relation(fields: [batchId], references: [id])
  member       Member?   @relation(fields: [memberId], references: [id])
  employeeUser User?     @relation("EmployeeCard", fields: [employeeUserId], references: [id])

  @@unique([tenantId, serialNumber])
  @@index([tenantId])
  @@index([batchId])
}

// ================== MEMBER ==================

model Member {
  id             String   @id @default(cuid())
  tenantId       String
  name           String
  phone          String
  email          String?
  points         Int      @default(0)
  depositBalance Int      @default(0)
  /// Jumlah stempel kartu loyalitas saat ini (buy X get 1 free) — direset ke 0 saat ditukar.
  stampCount     Int      @default(0)
  joinedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  uidCard           UidCard?
  pointTransactions PointTransaction[]
  stampTransactions StampTransaction[]
  sales             Sale[]
  laundryOrders     LaundryOrder[]
  bookings          Booking[]

  @@unique([tenantId, phone])
  @@index([tenantId])
}

enum PointTransactionType {
  EARN
  REDEEM
  ADJUST
}

enum StampTransactionType {
  EARN
  REDEEM
  ADJUST
}

model StampTransaction {
  id        String                @id @default(cuid())
  tenantId  String
  memberId  String
  type      StampTransactionType
  count     Int // positif untuk EARN, negatif untuk REDEEM/ADJUST
  saleId    String?
  note      String?
  createdAt DateTime              @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  sale   Sale?  @relation(fields: [saleId], references: [id])

  @@index([tenantId])
  @@index([memberId])
}

model PointTransaction {
  id        String               @id @default(cuid())
  tenantId  String
  memberId  String
  type      PointTransactionType
  points    Int // bisa negatif untuk REDEEM/ADJUST
  saleId    String?
  note      String?
  createdAt DateTime             @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  sale   Sale?  @relation(fields: [saleId], references: [id])

  @@index([tenantId])
  @@index([memberId])
}

enum GiftCardStatus {
  ACTIVE
  REDEEMED
  VOIDED
}

/// Voucher/gift card yang dijual di muka lalu ditukar sebagai metode bayar
/// saat checkout (saldo berkurang tiap dipakai, tidak terikat member tertentu).
model GiftCard {
  id           String         @id @default(cuid())
  tenantId     String
  code         String         @unique
  initialValue Int
  balance      Int
  status       GiftCardStatus @default(ACTIVE)
  buyerName    String?
  buyerPhone   String?
  note         String?
  soldById     String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  soldBy       User                  @relation(fields: [soldById], references: [id])
  transactions GiftCardTransaction[]

  @@index([tenantId])
}

enum GiftCardTransactionType {
  SALE
  REDEEM
  ADJUST
}

model GiftCardTransaction {
  id         String                   @id @default(cuid())
  tenantId   String
  giftCardId String
  type       GiftCardTransactionType
  amount     Int // positif untuk SALE (isi saldo), negatif untuk REDEEM/ADJUST
  saleId     String?
  note       String?
  createdAt  DateTime                 @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  giftCard GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  sale     Sale?    @relation(fields: [saleId], references: [id])

  @@index([tenantId])
  @@index([giftCardId])
}

// ================== PRODUK & STOK ==================

model Category {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]
  promos   Promo[]
  modifierGroups ModifierGroup[]

  @@index([tenantId])
}

enum ProductKind {
  GOODS
  SERVICE
  ASSEMBLY
  NON_INVENTORY
  COST
}

model Product {
  id                 String      @id @default(cuid())
  tenantId           String
  categoryId         String?
  name               String
  sku                String?
  price              Int // Rupiah, tanpa sen
  cost               Int?
  imageUrl           String?
  kind               ProductKind @default(GOODS)
  trackStock         Boolean     @default(true)
  trackExpiry        Boolean     @default(false)
  /// Lacak nomor seri/IMEI per unit (retail elektronik/HP) — tiap unit
  /// dijual satu-satu lewat ProductSerial, bukan cuma qty agregat.
  trackSerial        Boolean     @default(false)
  shelfLifeDays      Int?
  warrantyDays       Int?
  serviceDurationMin Int?
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])

  stocks             ProductStock[]
  saleItems          SaleItem[]
  stockAdjustments   StockAdjustment[]
  stockTransfers     StockTransfer[]
  tableOrderItems    TableOrderItem[]
  variantGroups      ProductVariantGroup[]
  modifierExclusions ProductModifierExclusion[]
  reorderPoints      StockReorderPoint[]
  stockBatches       StockBatch[]
  supplierContracts  SupplierPricingContract[]
  purchaseOrderItems PurchaseOrderItem[]
  stockReceiptItems  StockReceiptItem[]
  stockCountItems    StockCountItem[]
  costHistory        ProductCostHistory[]
  uoms               ProductUom[]
  wholesalePrices    WholesalePrice[]
  recipes            ProductRecipeItem[]       @relation("ProductRecipe")
  ingredients        ProductRecipeItem[]       @relation("ProductIngredient")
  serials            ProductSerial[]
  unavailabilityLogs ProductUnavailabilityLog[]

  @@index([tenantId])
  @@index([categoryId])
}

enum VariantGroupType {
  SINGLE // pilih 1 opsi, mis. Ukuran
  MULTIPLE // pilih banyak opsi, mis. Topping
}

/// Grup varian per produk, mis. "Ukuran" (SINGLE, wajib) atau "Topping" (MULTIPLE, opsional).
model ProductVariantGroup {
  id        String           @id @default(cuid())
  tenantId  String
  productId String
  name      String
  type      VariantGroupType @default(SINGLE)
  required  Boolean          @default(false)
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())

  tenant  Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  options ProductVariantOption[]

  @@index([tenantId])
  @@index([productId])
}

/// Opsi dalam satu grup varian, mis. "Large" (+5000) di grup "Ukuran".
model ProductVariantOption {
  id             String @id @default(cuid())
  tenantId       String
  variantGroupId String
  name           String
  priceDelta     Int    @default(0) // Rupiah, bisa 0 atau positif; ditambahkan ke harga produk
  sortOrder      Int    @default(0)

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variantGroup ProductVariantGroup @relation(fields: [variantGroupId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([variantGroupId])
}

/// Grup modifier menu, mis. "Level Gula" atau "Tambahan Espresso" — beda dari
/// ProductVariantGroup (per-produk satu-satu), ModifierGroup didaftar SEKALI
/// per kategori dan otomatis berlaku ke semua produk di kategori itu (dipakai
/// bareng di kasir & pemesanan QR meja). ProductModifierExclusion dipakai
/// kalau ada produk tertentu yang perlu dikecualikan dari modifier ini.
model ModifierGroup {
  id         String           @id @default(cuid())
  tenantId   String
  categoryId String
  name       String
  type       VariantGroupType @default(SINGLE)
  required   Boolean          @default(false)
  sortOrder  Int              @default(0)
  createdAt  DateTime         @default(now())

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  options  ModifierOption[]
  excludedFromProducts ProductModifierExclusion[]

  @@index([tenantId])
  @@index([categoryId])
}

/// Opsi dalam satu grup modifier, mis. "Less Sugar" (+0) atau "Double Shot" (+5000).
model ModifierOption {
  id              String @id @default(cuid())
  tenantId        String
  modifierGroupId String
  name            String
  priceDelta      Int    @default(0)
  sortOrder       Int    @default(0)

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([modifierGroupId])
}

/// Pengecualian: produk ini TIDAK ikut pakai ModifierGroup tertentu walau
/// satu kategori dengannya (mis. "Tambahan Espresso" dikecualikan dari "Es Teh Manis").
model ProductModifierExclusion {
  id              String @id @default(cuid())
  tenantId        String
  productId       String
  modifierGroupId String

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@unique([productId, modifierGroupId])
  @@index([tenantId])
}

model ProductStock {
  id        String   @id @default(cuid())
  tenantId  String
  productId String
  outletId  String
  qty       Int      @default(0)
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  outlet  Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@unique([productId, outletId])
  @@index([tenantId])
  @@index([outletId])
}

/// Jejak harian produk yang otomatis di-nonaktifkan di kasir karena bahan resepnya habis (D1) —
/// satu baris per produk per outlet per hari (di-upsert, gak numpuk tiap kali halaman kasir dibuka).
/// Dipakai buat insight "produk sering habis".
model ProductUnavailabilityLog {
  id        String   @id @default(cuid())
  tenantId  String
  outletId  String
  productId String
  date      DateTime // tengah malam hari itu (Asia/Jakarta), bukan timestamp presisi
  createdAt DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet  Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([tenantId, outletId, productId, date])
  @@index([tenantId])
  @@index([productId])
}

/// Jejak audit perubahan stok manual (lewat halaman Produk > Ubah).
/// Perubahan stok otomatis dari penjualan/void/retur TIDAK dicatat di sini
/// karena sudah punya jejaknya sendiri lewat Sale/SaleReturn.
enum StockAdjustmentReason {
  WASTE
  EXPIRED
  DAMAGED
  OTHER
}

model StockAdjustment {
  id          String   @id @default(cuid())
  tenantId    String
  productId   String
  outletId    String
  changedById String
  previousQty Int
  newQty      Int
  delta       Int
  note        String?
  /// Kategori alasan kalau ini adalah catatan kerugian (waste/expired/rusak/dll).
  /// null = koreksi stok biasa (bukan dari alur catat kerugian).
  reason      StockAdjustmentReason?
  createdAt   DateTime @default(now())

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  outlet    Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)
  changedBy User    @relation(fields: [changedById], references: [id])

  @@index([tenantId])
  @@index([productId])
  @@index([outletId])
}

enum StockTransferStatus {
  REQUESTED
  SENT
  RECEIVED
  REJECTED
  CANCELLED
}

/// Transfer stok antar outlet. Alur normal: request dibuat, stok outlet asal
/// berkurang saat dikirim, lalu stok outlet tujuan bertambah saat diterima.
model StockTransfer {
  id              String              @id @default(cuid())
  tenantId        String
  productId       String
  fromOutletId    String
  toOutletId      String
  transferredById String
  approvedById    String?
  sentById        String?
  receivedById    String?
  status          StockTransferStatus @default(RECEIVED)
  qty             Int
  sentQty         Int?
  receivedQty     Int?
  note            String?
  rejectReason    String?
  createdAt       DateTime            @default(now())
  approvedAt      DateTime?
  sentAt          DateTime?
  receivedAt      DateTime?
  rejectedAt      DateTime?
  cancelledAt     DateTime?

  tenant        Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  fromOutlet    Outlet  @relation("StockTransferFromOutlet", fields: [fromOutletId], references: [id], onDelete: Cascade)
  toOutlet      Outlet  @relation("StockTransferToOutlet", fields: [toOutletId], references: [id], onDelete: Cascade)
  transferredBy User    @relation("StockTransferCreatedBy", fields: [transferredById], references: [id])
  approvedBy    User?   @relation("StockTransferApprovedBy", fields: [approvedById], references: [id])
  sentBy        User?   @relation("StockTransferSentBy", fields: [sentById], references: [id])
  receivedBy    User?   @relation("StockTransferReceivedBy", fields: [receivedById], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([productId])
  @@index([fromOutletId])
  @@index([toOutletId])
}

// ================== SHIFT KASIR ==================

enum ShiftStatus {
  OPEN
  CLOSED
}

model CashierShift {
  id           String      @id @default(cuid())
  tenantId     String
  outletId     String
  userId       String
  openingCash  Int
  closingCash  Int?
  /// Rincian hitungan pecahan uang saat tutup shift, mis. {"100000": 5, "50000": 3, ...}
  /// — opsional, cuma keisi kalau kasir pakai kalkulator pecahan uang. Buat audit/dispute.
  closingCashBreakdown Json?
  expectedCash Int?
  /// Catatan alasan kalau selisih kas (closingCash vs expectedCash) melebihi batas wajar — wajib diisi saat itu terjadi.
  varianceNote String?
  status       ShiftStatus @default(OPEN)
  openedAt     DateTime    @default(now())
  closedAt     DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  sales               Sale[]
  cashOutTransactions CashOutTransaction[]
  saleReturns         SaleReturn[]

  @@index([tenantId])
  @@index([outletId])
}

// ================== PENJUALAN ==================

enum PaymentMethod {
  CASH
  QRIS
  TRANSFER
  EWALLET
  DEPOSIT
  GIFT_CARD
}

enum SaleStatus {
  COMPLETED
  VOIDED
}

enum CashOutMethod {
  DEBIT_CARD
  CREDIT_CARD
  QRIS
  TRANSFER
  EWALLET
}

enum CashOutStatus {
  COMPLETED
  VOIDED
}

model Sale {
  id             String        @id @default(cuid())
  tenantId       String
  outletId       String
  shiftId        String?
  cashierId      String
  memberId       String?
  invoiceNumber  String        @unique
  subtotal       Int
  discountAmount Int           @default(0)
  taxAmount      Int           @default(0)
  /// Markup harga per channel (mis. GoFood/GrabFood buat nutup potongan platform) — dari ChannelPricingRule.
  channelMarkupAmount Int      @default(0)
  total          Int
  /// Metode bayar utama — kalau isSplitPayment true, ini metode dengan porsi terbesar (buat laporan/summary lama tetap jalan).
  paymentMethod  PaymentMethod
  amountPaid     Int
  changeAmount   Int           @default(0)
  /// True kalau transaksi dibayar pakai lebih dari 1 metode — rincian per metode ada di relasi `payments`.
  isSplitPayment Boolean       @default(false)
  orderType      OrderType     @default(DINE_IN)
  cashbackAmount Int           @default(0)
  parkingFee     Int           @default(0)
  status         SaleStatus    @default(COMPLETED)
  voidReason     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet  Outlet        @relation(fields: [outletId], references: [id], onDelete: Cascade)
  shift   CashierShift? @relation(fields: [shiftId], references: [id])
  cashier User          @relation("SaleCashier", fields: [cashierId], references: [id])
  member  Member?       @relation(fields: [memberId], references: [id])

  items                SaleItem[]
  payments             SalePayment[]
  pointTransactions    PointTransaction[]
  stampTransactions    StampTransaction[]
  giftCardTransactions GiftCardTransaction[]
  saleReturns          SaleReturn[]
  tableOrder        TableOrder?
  bookingId         String?
  booking           Booking?      @relation(fields: [bookingId], references: [id])

  @@index([tenantId])
  @@index([outletId])
  @@index([shiftId])
  @@index([memberId])
}

/// Rincian per-metode buat transaksi split payment (Sale.isSplitPayment true) — mis. sebagian cash, sebagian QRIS.
model SalePayment {
  id       String        @id @default(cuid())
  tenantId String
  saleId   String
  method   PaymentMethod
  amount   Int

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([saleId])
}

model CashOutTransaction {
  id              String        @id @default(cuid())
  tenantId        String
  outletId        String
  shiftId         String
  cashierId       String
  referenceNumber String        @unique
  customerName    String?
  customerPhone   String?
  withdrawAmount  Int
  adminFee        Int           @default(0)
  totalCharged    Int
  method          CashOutMethod
  status          CashOutStatus @default(COMPLETED)
  voidReason      String?
  note            String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet  Outlet       @relation(fields: [outletId], references: [id], onDelete: Cascade)
  shift   CashierShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  cashier User         @relation("CashOutCashier", fields: [cashierId], references: [id])

  @@index([tenantId])
  @@index([outletId])
  @@index([shiftId])
  @@index([cashierId])
  @@index([status])
}

model SaleItem {
  id             String  @id @default(cuid())
  tenantId       String
  saleId         String
  productId      String
  productName    String // snapshot nama produk saat transaksi
  variantLabel   String? // snapshot pilihan varian, mis. "Large, Less Sugar, Boba"
  price          Int // snapshot harga saat transaksi (sudah termasuk priceDelta varian)
  qty            Int
  discountAmount Int     @default(0)
  subtotal       Int
  returnedQty    Int     @default(0) // akumulasi qty yang sudah diretur, tidak boleh melebihi qty

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  saleReturnItems SaleReturnItem[]
  serials         ProductSerial[]

  @@index([tenantId])
  @@index([saleId])
}

/// Retur sebagian dari transaksi yang sudah selesai (COMPLETED) — beda dengan
/// void (Sale.status VOIDED) yang membatalkan seluruh transaksi.
model SaleReturn {
  id            String   @id @default(cuid())
  tenantId      String
  saleId        String
  processedById String
  shiftId       String?
  reason        String
  totalRefund   Int
  refundMethod  String   @default("CASH") // "CASH", "TRANSFER", "DEPOSIT"
  createdAt     DateTime @default(now())

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale        Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  processedBy User             @relation("SaleReturnProcessedBy", fields: [processedById], references: [id])
  shift       CashierShift?    @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  items       SaleReturnItem[]

  @@index([tenantId])
  @@index([saleId])
  @@index([shiftId])
}

model SaleReturnItem {
  id           String @id @default(cuid())
  tenantId     String
  saleReturnId String
  saleItemId   String
  qty          Int
  refundAmount Int

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  saleReturn SaleReturn @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)
  saleItem   SaleItem   @relation(fields: [saleItemId], references: [id])

  @@index([tenantId])
  @@index([saleReturnId])
}

// ================== ABSENSI & JADWAL ==================

model ShiftSchedule {
  id           String        @id @default(cuid())
  tenantId     String
  outletId     String
  userId       String
  startAt      DateTime
  endAt        DateTime
  workType     ShiftWorkType @default(REGULAR)
  payType      ShiftPayType  @default(MONTHLY)
  shiftPay     Int?
  holidayBonus Int           @default(0)
  overtimeNote String?
  note         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([outletId])
  @@index([userId])
}

enum ShiftWorkType {
  REGULAR
  OVERTIME
  CASUAL
}

enum ShiftPayType {
  MONTHLY
  PER_SHIFT
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
}

model Attendance {
  id              String           @id @default(cuid())
  tenantId        String
  outletId        String
  userId          String
  clockInAt       DateTime?
  clockOutAt      DateTime?
  clockInPhotoUrl String?
  lat             Float?
  lng             Float?
  status          AttendanceStatus @default(PRESENT)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([outletId])
  @@index([userId])
}

// ================== PENGELUARAN OPERASIONAL ==================

enum ExpenseCategory {
  SEWA
  GAJI
  LISTRIK_AIR
  BAHAN_BAKU
  MARKETING
  TRANSPORT
  LAINNYA
}

model Expense {
  id          String          @id @default(cuid())
  tenantId    String
  outletId    String
  createdById String
  category    ExpenseCategory
  amount      Int
  note        String?
  spentAt     DateTime        @default(now())
  createdAt   DateTime        @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet    Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
  createdBy User   @relation(fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([outletId])
}

// ================== PESAN LEWAT QR MEJA ==================

/// Meja fisik di outlet. `qrToken` adalah ULID unik yang dicetak jadi QR code
/// dan dipakai di URL publik /pesan/[qrToken] — TIDAK boleh dipakai sebagai
/// pengganti tenantId untuk query lain, hanya untuk resolve meja dari QR.
model Table {
  id        String   @id @default(cuid())
  tenantId  String
  outletId  String
  name      String
  qrToken   String   @unique
  isActive  Boolean  @default(true)
  posX      Int      @default(0)
  posY      Int      @default(0)
  floor     Int      @default(1)
  shape     String   @default("SQUARE")
  capacity  Int      @default(2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  orders TableOrder[]

  @@index([tenantId])
  @@index([outletId])
}

enum TableOrderStatus {
  PENDING
  ACCEPTED
  READY
  DONE
  CANCELLED
}

/// Pesanan yang dikirim pelanggan lewat halaman publik /pesan/[qrToken].
/// Stok produk trackStock LANGSUNG dipotong (direservasi) secara atomik saat
/// pesanan dibuat — supaya beberapa meja yang pesan barang sama persis di
/// waktu bersamaan tidak sama-sama lolos padahal stoknya cuma cukup untuk satu.
/// Saat staff menekan "Proses Pembayaran", transaksi (Sale) dibuat langsung dari
/// item pesanan ini TANPA memotong stok lagi (sudah direservasi di awal).
model TableOrder {
  id           String           @id @default(cuid())
  tenantId     String
  outletId     String
  tableId      String
  saleId       String?          @unique
  customerName String?
  note         String?
  status       TableOrderStatus @default(PENDING)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
  table  Table  @relation(fields: [tableId], references: [id], onDelete: Cascade)
  sale   Sale?  @relation(fields: [saleId], references: [id])

  items TableOrderItem[]

  @@index([tenantId])
  @@index([outletId])
  @@index([tableId])
}

model TableOrderItem {
  id           String  @id @default(cuid())
  tenantId     String
  tableOrderId String
  productId    String
  productName  String // snapshot nama produk saat pesan
  variantLabel String? // snapshot pilihan varian, mis. "Large, Less Sugar, Boba"
  price        Int // snapshot harga saat pesan (sudah termasuk priceDelta varian)
  qty          Int
  note         String?

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tableOrder TableOrder @relation(fields: [tableOrderId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([tableOrderId])
}

// ================== BILLING & LANGGANAN ==================

enum SubscriptionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Permintaan upgrade paket dari Owner. Pembayaran dilakukan manual (transfer)
/// di luar sistem — super-admin platform yang mengonfirmasi lewat panel
/// /superadmin setelah memverifikasi dana masuk, baru Tenant.plan berubah.
model SubscriptionRequest {
  id            String                    @id @default(cuid())
  tenantId      String
  requestedPlan Plan
  status        SubscriptionRequestStatus @default(PENDING)
  note          String?
  reviewNote    String?
  createdAt     DateTime                  @default(now())
  reviewedAt    DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ================== AUDIT LOG ==================

enum AuditAction {
  SALE_VOID
  SALE_RETURN
  SALE_PAYMENT_CORRECTION
  PRODUCT_PRICE_CHANGE
  PRODUCT_DEACTIVATE
  PRODUCT_ACTIVATE
  PRODUCT_DELETE
  USER_PASSWORD_RESET
  PERIOD_LOCK
  PERIOD_UNLOCK
}

/// Jejak aksi sensitif: siapa melakukan apa dan kapan. Hanya dicatat untuk
/// aksi yang berdampak ke uang/data (void, retur, ubah harga, nonaktifkan
/// produk, dst) — bukan log aktivitas umum.
model AuditLog {
  id          String      @id @default(cuid())
  tenantId    String
  userId      String
  action      AuditAction
  description String
  createdAt   DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
}

// ================== PROMO TERJADWAL ==================

enum PromoDiscountType {
  PERCENT
  FIXED
}

enum PromoScope {
  ALL
  CATEGORY
}

/// Promo otomatis (happy hour, diskon kategori, minimal belanja) yang aktif
/// sendiri sesuai jadwal — tidak perlu diinput manual oleh kasir. Dievaluasi
/// dari waktu server saat kasir membuka halaman Kasir (lihat kasir-service).
model Promo {
  id            String            @id @default(cuid())
  tenantId      String
  name          String
  discountType  PromoDiscountType
  discountValue Int // persen (0-100) kalau PERCENT, Rupiah kalau FIXED
  scope         PromoScope        @default(ALL)
  categoryId    String?
  minSpend      Int               @default(0) // 0 = tanpa syarat minimal belanja
  daysOfWeek    Int[] // 0=Minggu..6=Sabtu; kosong = berlaku tiap hari
  startTime     String // format "HH:mm", jam mulai
  endTime       String // format "HH:mm", jam selesai
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])

  @@index([tenantId])
}

// ================== BOOKING / APPOINTMENT ==================

enum BookingType {
  APPOINTMENT // janji potong rambut dsb, biasanya di tempat
  DELIVERY // pesan untuk diantar / dipanggil ke acara
}

enum BookingStatus {
  PENDING
  CONFIRMED
  DONE
  CANCELLED
}

/// Booking dicatat staff saat pelanggan menelepon/datang minta jadwal —
/// TIDAK ada halaman publik self-booking (di luar skop saat ini). Cocok
/// untuk barbershop (janji potong rambut) maupun F&B (pesan diantar/dibawa
/// ke acara).
model Booking {
  id              String        @id @default(cuid())
  tenantId        String
  outletId        String
  type            BookingType   @default(APPOINTMENT)
  /// Auto-matched dari customerPhone kalau nomornya kedaftar sebagai member — biar dapat poin & histori.
  memberId        String?
  customerName    String
  customerPhone   String?
  serviceName     String
  scheduledAt     DateTime
  durationMinutes Int           @default(60)
  staffUserId     String?
  pax             Int?
  eventAddress    String?
  quotedAmount    Int?
  transportFee    Int           @default(0)
  staffFee        Int           @default(0)
  depositAmount   Int           @default(0)
  status          BookingStatus @default(PENDING)
  note            String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)
  staff  User?   @relation(fields: [staffUserId], references: [id])
  member Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  sales  Sale[]

  @@index([tenantId])
  @@index([outletId])
  @@index([staffUserId])
  @@index([memberId])
}

// ================== LAUNDRY ==================

enum LaundryServiceType {
  KILOAN
  SATUAN
  DRY_CLEAN
  SETRIKA
  EXPRESS
}

enum LaundryOrderStatus {
  RECEIVED
  WASHING
  DRYING
  IRONING
  READY
  PICKED_UP
  CANCELLED
}

/// Order laundry butuh tracking lifecycle fisik dari drop-off sampai pickup.
/// `weightGram` dipakai supaya harga kiloan tetap integer tanpa floating point.
model LaundryOrder {
  id               String             @id @default(cuid())
  tenantId         String
  outletId         String
  laundryServiceId String?
  /// Auto-matched dari customerPhone kalau nomornya kedaftar sebagai member — biar dapat poin & histori.
  memberId         String?
  orderNumber      String             @unique
  customerName     String
  customerPhone    String?
  serviceType      LaundryServiceType @default(KILOAN)
  serviceName      String?
  weightGram       Int?
  itemQty          Int?
  pricePerKg       Int?
  servicePrice     Int                @default(0)
  extraFee         Int                @default(0)
  discountAmount   Int                @default(0)
  total            Int
  paidAmount       Int                @default(0)
  dueAt            DateTime?
  pickupDelivery   Boolean            @default(false)
  deliveryAddress  String?
  status           LaundryOrderStatus @default(RECEIVED)
  /// Jaga dari poin dobel kalau staff toggle status maju-mundur (bisa PICKED_UP lebih dari sekali).
  pointsAwarded    Boolean            @default(false)
  note             String?
  createdById      String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet         Outlet          @relation(fields: [outletId], references: [id], onDelete: Cascade)
  laundryService LaundryService? @relation(fields: [laundryServiceId], references: [id], onDelete: SetNull)
  member         Member?         @relation(fields: [memberId], references: [id], onDelete: SetNull)
  createdBy      User            @relation("LaundryOrderCreatedBy", fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([outletId])
  @@index([laundryServiceId])
  @@index([memberId])
  @@index([status])
  @@index([dueAt])
}

model LaundryService {
  id           String             @id @default(cuid())
  tenantId     String
  name         String
  serviceType  LaundryServiceType @default(KILOAN)
  pricePerKg   Int?
  servicePrice Int                @default(0)
  isActive     Boolean            @default(true)
  sortOrder    Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders LaundryOrder[]

  @@index([tenantId])
  @@index([isActive])
}

// ================== MAINTENANCE ALAT ==================

enum EquipmentStatus {
  ACTIVE
  NEEDS_REPAIR
  REPAIRING
  RETIRED
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

model Equipment {
  id           String          @id @default(cuid())
  tenantId     String
  outletId     String
  name         String
  category     String
  serialNumber String?
  status       EquipmentStatus @default(ACTIVE)
  note         String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  tenant Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet Outlet                    @relation(fields: [outletId], references: [id], onDelete: Cascade)
  logs   EquipmentMaintenanceLog[]

  @@index([tenantId])
  @@index([outletId])
  @@index([status])
}

model EquipmentMaintenanceLog {
  id           String            @id @default(cuid())
  tenantId     String
  outletId     String
  equipmentId  String
  reportedById String
  status       MaintenanceStatus @default(OPEN)
  issue        String
  actionTaken  String?
  cost         Int               @default(0)
  reportedAt   DateTime          @default(now())
  resolvedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet     Outlet    @relation(fields: [outletId], references: [id], onDelete: Cascade)
  equipment  Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  reportedBy User      @relation(fields: [reportedById], references: [id])

  @@index([tenantId])
  @@index([outletId])
  @@index([equipmentId])
  @@index([status])
}

// ================== INVENTORY ENHANCEMENTS ==================

/// Reorder point per produk per outlet — minimal stok yang harus dijaga.
/// Kalau stok turun di bawah ini, tampilkan warning di dashboard.
model StockReorderPoint {
  id        String   @id @default(cuid())
  tenantId  String
  productId String
  outletId  String
  minQty    Int      @default(5) // minimal qty sebelum warning
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  outlet  Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@unique([productId, outletId])
  @@index([tenantId])
}

/// Stock batch/lot tracking untuk FMCG, makanan, farmasi.
/// Catat batch number, exp date, dan kuantitas yang masuk per batch.
model StockBatch {
  id             String    @id @default(cuid())
  tenantId       String
  productId      String
  outletId       String
  batchNumber    String
  expirationDate DateTime?
  qtyReceived    Int
  qtyRemaining   Int
  receivedDate   DateTime  @default(now())
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  outlet  Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productId])
  @@index([outletId])
  @@index([expirationDate])
}

enum ProductSerialStatus {
  IN_STOCK
  SOLD
}

/// Nomor seri/IMEI per unit fisik (retail elektronik/HP) — beda dengan
/// StockBatch yang lacak sekelompok stok, ini satu baris = satu unit barang.
model ProductSerial {
  id           String              @id @default(cuid())
  tenantId     String
  productId    String
  outletId     String
  serialNumber String
  status       ProductSerialStatus @default(IN_STOCK)
  saleItemId   String?
  createdAt    DateTime            @default(now())
  soldAt       DateTime?

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  outlet   Outlet    @relation(fields: [outletId], references: [id], onDelete: Cascade)
  saleItem SaleItem? @relation(fields: [saleItemId], references: [id])

  @@unique([tenantId, serialNumber])
  @@index([tenantId, productId, outletId, status])
  @@index([saleItemId])
}

// ================== SUPPLIER & PURCHASE MANAGEMENT ==================

enum SupplierStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

model Supplier {
  id            String         @id @default(cuid())
  tenantId      String
  name          String
  address       String?
  city          String?
  phone         String?
  email         String?
  contactPerson String?
  paymentTerms  String? // "Net 30", "COD", "DP 50%", dll
  taxId         String? // NPWP
  rating        Int? // 1-5 bintang
  notes         String?
  status        SupplierStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant           Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders   PurchaseOrder[]
  pricingContracts SupplierPricingContract[]
  invoices         SupplierInvoice[]

  @@index([tenantId])
}

/// Harga khusus supplier per produk dengan minimal order.
model SupplierPricingContract {
  id         String   @id @default(cuid())
  tenantId   String
  supplierId String
  productId  String
  unitPrice  Int // Rupiah per unit
  minQty     Int      @default(1) // Minimal order quantity
  leadDays   Int      @default(3) // Berapa hari pengiriman
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([supplierId, productId])
  @@index([tenantId])
  @@index([productId])
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id            String              @id @default(cuid())
  tenantId      String
  supplierId    String
  poNumber      String // Auto: PO-20250704-001
  status        PurchaseOrderStatus @default(DRAFT)
  sentAt        DateTime?
  expectedAt    DateTime?
  receivedAt    DateTime?
  totalAmount   Int // Rupiah, calculated
  approvedById  String? // User yang approve
  rejectionNote String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier      Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  approvedBy    User?               @relation(fields: [approvedById], references: [id])
  items         PurchaseOrderItem[]
  stockReceipts StockReceipt[]

  @@index([tenantId])
  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id          String   @id @default(cuid())
  poId        String
  productId   String
  qty         Int
  unitPrice   Int // Rupiah
  subtotal    Int // qty * unitPrice
  qtyReceived Int      @default(0)
  createdAt   DateTime @default(now())

  po      PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id])

  @@index([poId])
  @@index([productId])
}

enum StockReceiptStatus {
  PENDING // Goods masuk, belum QC
  PARTIAL_QC // Sebagian sudah QC
  COMPLETED // Semua QC selesai, stok masuk
  REJECTED // Ada yang reject
}

/// Goods received dari supplier (linked ke PurchaseOrder).
model StockReceipt {
  id            String             @id @default(cuid())
  tenantId      String
  poId          String
  outletId      String
  receiptNumber String // Auto: GR-20250704-001
  status        StockReceiptStatus @default(PENDING)
  /// Landed cost — ongkos kirim & biaya lain (bea, handling, dll) yang
  /// didistribusi pro-rata ke cost tiap item saat completeReceipt().
  shippingCost  Int                @default(0)
  otherCost     Int                @default(0)
  receivedAt    DateTime           @default(now())
  completedAt   DateTime?
  receivedById  String?
  checkedById   String?
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  po         PurchaseOrder      @relation(fields: [poId], references: [id], onDelete: Cascade)
  outlet     Outlet             @relation(fields: [outletId], references: [id], onDelete: Cascade)
  receivedBy User?              @relation("StockReceiptReceivedBy", fields: [receivedById], references: [id])
  checkedBy  User?              @relation("StockReceiptCheckedBy", fields: [checkedById], references: [id])
  items      StockReceiptItem[]

  @@index([tenantId])
  @@index([poId])
  @@index([outletId])
}

enum QCStatus {
  PENDING // Belum QC
  PASSED // Lolos QC
  PARTIAL_DEFECT // Ada yang rusak
  REJECTED // Semua reject
}

model StockReceiptItem {
  id          String   @id @default(cuid())
  receiptId   String
  productId   String
  qtyReceived Int // Dari PO
  qtyAccepted Int      @default(0) // Lolos QC
  qtyDefect   Int      @default(0) // Rusak/bermasalah
  batchNumber String?
  expirationDate DateTime?
  /// Nomor seri/IMEI per unit (kalau produknya trackSerial) — satu entri per unit qtyAccepted.
  serialNumbers String[] @default([])
  qcStatus    QCStatus @default(PENDING)
  qcNotes     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  receipt StockReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id])

  @@index([receiptId])
  @@index([productId])
}

enum StockCountStatus {
  DRAFT // Belum mulai count
  IN_PROGRESS // Sedang di-count
  COMPLETED // Selesai count
  VERIFIED // Admin sudah verify adjustment
}

/// Physical inventory count (opname).
model StockCount {
  id            String           @id @default(cuid())
  tenantId      String
  outletId      String
  countDate     DateTime
  countNumber   String // Auto: SC-20250704-001
  status        StockCountStatus @default(DRAFT)
  startedBy     String?
  completedBy   String?
  verifiedBy    String?
  totalVariance Int              @default(0) // Total nilai variance Rupiah
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet          Outlet           @relation(fields: [outletId], references: [id], onDelete: Cascade)
  startedByUser   User?            @relation("StockCountStartedBy", fields: [startedBy], references: [id])
  completedByUser User?            @relation("StockCountCompletedBy", fields: [completedBy], references: [id])
  verifiedByUser  User?            @relation("StockCountVerifiedBy", fields: [verifiedBy], references: [id])
  items           StockCountItem[]

  @@index([tenantId])
  @@index([outletId])
  @@index([countDate])
}

model StockCountItem {
  id            String  @id @default(cuid())
  countId       String
  productId     String
  systemQty     Int // Qty di sistem
  physicalQty   Int     @default(0) // Qty hasil count fisik
  variance      Int     @default(0) // physicalQty - systemQty
  varianceValue Int     @default(0) // variance * harga jual
  notes         String?

  count   StockCount @relation(fields: [countId], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [productId], references: [id])

  @@index([countId])
  @@index([productId])
}

/// Track setiap perubahan harga/cost produk dari supplier.
model ProductCostHistory {
  id           String   @id @default(cuid())
  tenantId     String
  productId    String
  previousCost Int?
  newCost      Int
  reason       String? // "Supplier price change", "Manual adjustment", dll
  changedBy    String? // User yang ubah
  createdAt    DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  user    User?   @relation(fields: [changedBy], references: [id])

  @@index([tenantId])
  @@index([productId])
}

// ================== PENGATURAN TENANT ==================

model TenantSetting {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  taxPercent        Int      @default(0)
  pointsPerAmount   Int            @default(10000) // 1 poin per Rp10.000
  receiptFooter     String?
  staticQrisPayload String?
  enableParkingFee  Boolean        @default(false)
  accountingMode    AccountingMode @default(SIMPLE)
  /// Tanggal terakhir yang sudah "ditutup" (kunci pembukuan) — tidak ada jurnal
  /// baru/void/retur/hapus pengeluaran yang boleh menyentuh tanggal ini ke belakang.
  /// null = belum pernah tutup buku, semua tanggal masih terbuka.
  periodLockDate    DateTime?
  /// Kartu stempel: 1 stempel per transaksi member, gratis reward saat capai target.
  stampProgramEnabled Boolean @default(false)
  stampTarget         Int     @default(10)
  stampRewardName     String?
  /// Nilai reward gratis (Rp) yang dipotong dari total saat stempel ditukar.
  stampRewardValue    Int     @default(0)
  updatedAt         DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

enum AccountingMode {
  SIMPLE
  ADVANCED
}

// ================== DOKUMEN & E-SIGN ==================

enum DocumentStatus {
  DRAFT
  PENDING_SIGNATURE
  IN_PROGRESS
  SIGNED
  REJECTED
  EXPIRED
}

enum SignerStatus {
  PENDING
  SIGNED
  REJECTED
  SKIPPED
}

enum DocumentAccessLevel {
  OWNER
  EDITOR
  VIEWER
  SIGNER
}

model Document {
  id          String         @id @default(cuid())
  tenantId    String
  name        String
  description String?
  fileUrl     String // Data URL base64 (lihat docs/SKEMA-DATABASE.md § Dokumen)
  status      DocumentStatus @default(DRAFT)
  uploadedBy  String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  expiresAt   DateTime?

  // Relations
  versions      DocumentVersion[]
  signers       DocumentSigner[]
  accessControl DocumentAccess[]

  uploader User   @relation("DocumentUploader", fields: [uploadedBy], references: [id], onDelete: Cascade)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([uploadedBy])
  @@index([status])
}

model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String
  version    Int      @default(1)
  fileUrl    String
  createdAt  DateTime @default(now())
  createdBy  String

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  creator  User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
  @@index([documentId])
}

model DocumentSigner {
  id              String       @id @default(cuid())
  documentId      String
  userId          String
  sequence        Int // Urutan signing (1, 2, 3, dst)
  status          SignerStatus @default(PENDING)
  signedAt        DateTime?
  signatureData   String? // Canvas signature data (base64)
  rejectionReason String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signer   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId])
  @@index([documentId])
  @@index([userId])
  @@index([status])
}

model DocumentAccess {
  id         String              @id @default(cuid())
  documentId String
  userId     String? // NULL jika untuk role
  role       String? // OWNER/MANAGER/STAFF atau null jika specific user
  level      DocumentAccessLevel @default(VIEWER)
  createdAt  DateTime            @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId])
  @@index([documentId])
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  COURIER
  GRABFOOD
  GOFOOD
  SHOPEEFOOD
  MAXIM
  DELIVERY_OTHER
}

model ProductUom {
  id             String   @id @default(cuid())
  tenantId       String
  productId      String
  name           String
  conversionRate Int      @default(1)
  price          Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productId])
}

model WholesalePrice {
  id        String   @id @default(cuid())
  tenantId  String
  productId String
  minQty    Int      @default(1)
  price     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productId])
}

/// Markup harga per channel/order type (mis. GoFood/GrabFood ditambah 20% buat
/// nutup potongan platform). markupPercent bisa negatif buat diskon channel.
model ChannelPricingRule {
  id            String    @id @default(cuid())
  tenantId      String
  orderType     OrderType
  markupPercent Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, orderType])
  @@index([tenantId])
}

model ProductRecipeItem {
  id           String   @id @default(cuid())
  tenantId     String
  productId    String
  ingredientId String
  qty          Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product    Product @relation("ProductRecipe", fields: [productId], references: [id], onDelete: Cascade)
  ingredient Product @relation("ProductIngredient", fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productId])
  @@index([ingredientId])
}

enum SupplierInvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  VOIDED
}

model SupplierInvoice {
  id              String                @id @default(cuid())
  tenantId        String
  supplierId      String
  outletId        String?
  invoiceNumber   String
  invoiceDate     DateTime
  dueDate         DateTime?
  subtotal        Int
  discountAmount  Int                   @default(0)
  taxAmount       Int                   @default(0)
  total           Int
  paidAmount      Int                   @default(0)
  status          SupplierInvoiceStatus @default(UNPAID)
  purchaseOrderId String?
  stockReceiptId  String?
  notes           String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier          @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  payments SupplierPayment[]

  @@index([tenantId])
  @@index([supplierId])
}

model SupplierPayment {
  id                String   @id @default(cuid())
  tenantId          String
  supplierInvoiceId String
  paymentDate       DateTime
  amount            Int
  paymentMethod     String   @default("CASH") // "CASH", "BANK", etc
  notes             String?
  createdAt         DateTime @default(now())

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice SupplierInvoice @relation(fields: [supplierInvoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([supplierInvoiceId])
}

model Account {
  id        String      @id @default(cuid())
  tenantId  String
  code      String // e.g., "11100" for Cash Drawer
  name      String // e.g., "Cash Drawer"
  type      AccountType
  createdAt DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model JournalEntry {
  id          String   @id @default(cuid())
  tenantId    String
  date        DateTime @default(now())
  description String
  debitCode   String
  creditCode  String
  amount      Int      // Rupiah
  reference   String?  // e.g., "SALE-123", "EXP-456"
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

enum LeadStatus {
  NEW
  CONTACTED
  WON
  LOST
}

model Lead {
  id             String     @id @default(cuid())
  tenantId       String
  name           String
  phone          String?
  email          String?
  source         String?    // e.g. "Instagram", "WhatsApp", "Rekomendasi"
  interest       String?    // e.g. "Catering Event", "Kopi Bubuk Grosir"
  expectedValue  Int        @default(0)
  nextFollowUpAt DateTime?
  status         LeadStatus @default(NEW)
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

enum CashFlowType {
  IN
  OUT
}

model CashFlow {
  id          String       @id @default(cuid())
  tenantId    String
  outletId    String
  createdById String
  type        CashFlowType
  category    String       // e.g., "Penjualan", "Modal", "Sewa", "Gaji", "Bahan Baku", "Lainnya"
  amount      Int
  note        String?
  spentAt     DateTime     @default(now())
  createdAt   DateTime     @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet    Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
  createdBy User   @relation("UserCashFlows", fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([outletId])
}

// ================== BILLING & SUBSCRIPTION (SUMOPOD) ==================

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PAST_DUE
  TRIALING
}

model Subscription {
  id String @id @default(cuid())
  tenantId String @unique
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  plan Plan @default(FREE)
  status SubscriptionStatus @default(ACTIVE)

  billingCycle String @default("MONTHLY") // MONTHLY, YEARLY
  currentPeriodStart DateTime
  currentPeriodEnd DateTime
  nextBillingDate DateTime?

  lastPaymentId String?
  lastPaymentAmount Int?
  lastPaymentDate DateTime?

  trialStartDate DateTime?
  trialEndDate DateTime?
  isOnTrial Boolean @default(false)

  autoRenew Boolean @default(true)
  cancelledAt DateTime?
  cancelledReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]
  paymentHistory PaymentHistory[]

  @@index([tenantId])
  @@index([status])
  @@index([currentPeriodEnd])
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id String @id @default(cuid())
  subscriptionId String
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  invoiceNumber String @unique
  sumopodPaymentId String?

  amount Int
  tax Int @default(0)
  total Int

  currency String @default("IDR")

  status InvoiceStatus @default(DRAFT)
  dueDate DateTime
  paidDate DateTime?

  description String

  fromDate DateTime
  toDate DateTime

  items Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  paymentHistory PaymentHistory[]

  @@index([subscriptionId])
  @@index([status])
  @@index([invoiceNumber])
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  EXPIRED
}

model PaymentHistory {
  id String @id @default(cuid())
  subscriptionId String
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  sumopodPaymentId String @unique
  invoiceId String
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  amount Int
  currency String @default("IDR")

  paymentMethod String?
  status PaymentStatus @default(PENDING)

  failureReason String?

  createdAt DateTime @default(now())
  processedAt DateTime?

  metadata Json?

  @@index([subscriptionId])
  @@index([sumopodPaymentId])
  @@index([status])
}
